<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="YouTubeHelper.Mobile.Views.VideoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">
    <VerticalStackLayout>
        <StackLayout>
            <StackLayout.Behaviors>
                <toolkit:AnimationBehavior>
                    <toolkit:AnimationBehavior.AnimationType>
                        <toolkit:FadeAnimation Opacity="0.5" />
                    </toolkit:AnimationBehavior.AnimationType>
                </toolkit:AnimationBehavior>
            </StackLayout.Behaviors>

            <StackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding VideoTappedCommand}" />
            </StackLayout.GestureRecognizers>

            <Grid x:Name="VideoGrid" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,10"
                    FontAttributes="Bold"
                    LineBreakMode="TailTruncation"
                    MaxLines="5"
                    Text="{Binding VideoTitle}" />

                <Grid Grid.Row="1" Grid.Column="0">
                    <BoxView HeightRequest="112.5" Color="LightGray">
                        <BoxView.Clip>
                            <RoundRectangleGeometry CornerRadius="8" Rect="0, 0, 200, 112.5" />
                        </BoxView.Clip>
                    </BoxView>

                    <Image HeightRequest="112.5">
                        <Image.Source>
                            <UriImageSource CachingEnabled="False" Uri="{Binding Video.ThumbnailUrl}" />
                        </Image.Source>
                        <Image.Clip>
                            <RoundRectangleGeometry CornerRadius="8" Rect="0, 0, 200, 112.5" />
                        </Image.Clip>
                    </Image>
                </Grid>

                <StackLayout Grid.Row="1" Grid.Column="1">
                    <Label Margin="10,0,10,0" Text="{Binding Video.TimeStringNewLine}" />
                    <Label
                        Margin="10,0,10,0"
                        FontAttributes="Bold"
                        IsVisible="{Binding Video.New}"
                        Text="NEW!"
                        TextColor="Goldenrod" />
                    <Label
                        Margin="10,0,10,0"
                        FontAttributes="Bold"
                        IsVisible="{Binding Video.Excluded}"
                        Text="{Binding ExcludedString}"
                        TextColor="FireBrick" />
                    <Label
                        Margin="10,0,10,0"
                        FontAttributes="Bold"
                        IsVisible="{Binding HasStatus}"
                        Text="{Binding Video.Status}"
                        TextColor="Green" />
                    <Label
                        Margin="10,0,10,0"
                        FontAttributes="Bold"
                        IsVisible="{Binding IsPlaying}"
                        Text="▶" />
                </StackLayout>
            </Grid>
        </StackLayout>

        <!--  Side-by-side Description | Comments headers  -->
        <HorizontalStackLayout Margin="10,0,10,0">
            <Label
Text="▶ Description">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleDescriptionCommand}" NumberOfTapsRequired="1" />
                </Label.GestureRecognizers>
                <Label.Triggers>
                    <DataTrigger Binding="{Binding IsDescriptionExpanded}" TargetType="Label" Value="True">
                        <Setter Property="Text" Value="▼ Description" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <Label
                Margin="16,0,0,0"
Text="▶ Comments">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleTopCommentsCommand}" NumberOfTapsRequired="1" />
                </Label.GestureRecognizers>
                <Label.Triggers>
                    <DataTrigger Binding="{Binding IsTopCommentsExpanded}" TargetType="Label" Value="True">
                        <Setter Property="Text" Value="▼ Comments" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
        </HorizontalStackLayout>

        <!--  Description expanded content  -->
        <Label
            IsVisible="{Binding IsDescriptionExpanded}"
            Padding="10,4,10,0"
            FormattedText="{Binding FormattedDescription}">
        </Label>

        <!--  Top Comments expanded content  -->
        <VerticalStackLayout IsVisible="{Binding IsTopCommentsExpanded}" Margin="10,4,10,0">
            <Label
                IsVisible="{Binding IsLoadingComments}"
                Text="Loading..."
                TextColor="Gray" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding TopComments}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Margin="0,8,0,0">
                            <HorizontalStackLayout>
                                <Label FontAttributes="Bold" Text="{Binding AuthorDisplayName}" />
                                <Label
                                    Margin="6,0,0,0"
                                    Text="• Creator"
                                    TextColor="#1565C0"
                                    IsVisible="{Binding IsCreatorComment}" />
                                <Label
                                    Margin="8,0,0,0"
                                    Text="{Binding LikeCount, StringFormat='👍 {0}'}"
                                    TextColor="Gray" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding Text}" />
                            <!--  Nested replies: creator replies or replies that beat the parent like count  -->
                            <VerticalStackLayout Margin="16,4,0,0" BindableLayout.ItemsSource="{Binding Replies}" IsVisible="{Binding HasReplies}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Margin="0,4,0,0">
                                            <HorizontalStackLayout>
                                                <Label Text="↳ " TextColor="Gray" />
                                                <Label FontAttributes="Bold" Text="{Binding AuthorDisplayName}" />
                                                <Label
                                                    Margin="6,0,0,0"
                                                    Text="• Creator"
                                                    TextColor="#1565C0"
                                                    IsVisible="{Binding IsCreatorComment}" />
                                                <Label
                                                    Margin="8,0,0,0"
                                                    Text="{Binding LikeCount, StringFormat='👍 {0}'}"
                                                    TextColor="Gray" />
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding Text}" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
            <Label
                IsVisible="{Binding HasNoComments}"
                Text="No comments available."
                TextColor="Gray" />
        </VerticalStackLayout>

        <!--  Divider  -->
        <BoxView
            Margin="10,5,10,0"
            Color="LightGray"
            CornerRadius="3"
            HeightRequest="6"
            HorizontalOptions="Fill" />
    </VerticalStackLayout>
</ContentView>
